],"y":5860,"opacity":100,"height":240,"width":540.00000000000011,"frameId":"zwHZW-FslHRFxSNZRdbqr","strokeStyle":"solid","versionNonce":1972273503},{"isDeleted":true,"locked":false,"strokeColor":"transparent","link":null,"status":"saved","roughness":0,"groupIds":["R7Zpr4Isf6zfrHopH-tt4","62bq_tkki6jhixpW-9Skc"],"index":"b96zzyl","backgroundColor":"transparent","fileId":"c2ee78704b377e53364833368f6a754aef90269f","angle":0,"fillStyle":"solid","crop":{"y":0,"width":254.04166666666663,"naturalWidth":469,"height":237,"x":0,"naturalHeight":237},"strokeWidth":1,"version":263,"roundness":null,"type":"image","updated":1782160491313,"id":"uZZMuq2CJfhreCu6PPHGj","x":2600,"seed":1406192864,"boundElements":[],"y":5860,"opacity":100,"height":242.55863539445625,"scale":[1,1],"width":260,"frameId":"zwHZW-FslHRFxSNZRdbqr","strokeStyle":"solid","versionNonce":1369180177},{"isDeleted":true,"locked":false,"strokeColor":"transparent","link":null,"status":"saved","roughness":0,"groupIds":["R7Zpr4Isf6zfrHopH-tt4","62bq_tkki6jhixpW-9Skc"],"index":"b96zzz","backgroundColor":"transparent","fileId":"ed0e8aded23154cc9760db7924e51a4414b07565","angle":0,"fillStyle":"solid","crop":null,"strokeWidth":1,"version":209,"roundness":null,"type":"image","updated":1782160491313,"id":"uABwedFRexC8gn0bX5hw-","x":2860,"seed":318573792,"boundElements":[],"y":5880,"opacity":100,"height":199.99999999999966,"scale":[1,1],"width":230.70866141732245,"frameId":"zwHZW-FslHRFxSNZRdbqr","strokeStyle":"solid","versionNonce":739573119},{"seed":453217504,"strokeStyle":"solid","id":"26HpRV67CPUbf2HykjnsX","strokeWidth":1,"roughness":0,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491313,"locked":false,"text":"Эмиттер – это область транзистора, которая вводит (инжектирует) носители заряда (электроны или дырки) в область базы. Он\nобеспечивает ввод носителей заряда в транзистор.\n\nОсобенности:\n- обычно сильно легируется (имеет высокую концентрацию примесей), чтобы обеспечить высокую концентрацию носителей заряда;\n- обеспечивает ввод или вывод носителей заряда в транзистор.","version":321,"autoResize":false,"type":"text","backgroundColor":"#ffffff","index":"b96zzzC","roundness":null,"containerId":null,"originalText":"Эмиттер – это область транзистора, которая вводит (инжектирует) носители заряда (электроны или дырки) в область базы. Он обеспечивает ввод носителей заряда в транзистор.\n\nОсобенности:\n- обычно сильно легируется (имеет высокую концентрацию примесей), чтобы обеспечить высокую концентрацию носителей заряда;\n- обеспечивает ввод или вывод носителей заряда в транзистор.","height":120,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":["62bq_tkki6jhixpW-9Skc"],"versionNonce":165862897,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"zwHZW-FslHRFxSNZRdbqr","boundElements":[],"x":3140,"angle":0,"y":5860,"width":1059.9999999999995},{"seed":1614286048,"strokeStyle":"solid","id":"hC3s5v7bK5nLKmHuW4Ljz","strokeWidth":1,"roughness":0,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491313,"locked":false,"text":"Коллектор – это область, которая собирает носители заряда, прошедшие через базу. \n\nОсобенности:\n- обычно имеет большую площадь и умеренно сильное легирование, чтобы эффективно собирать большое количество носителей заряда;\n- через коллектор протекает основной ток устройства.","version":364,"autoResize":false,"type":"text","backgroundColor":"#ffffff","index":"b96zzzO","roundness":null,"containerId":null,"originalText":"Коллектор – это область, которая собирает носители заряда, прошедшие через базу. \n\nОсобенности:\n- обычно имеет большую площадь и умеренно сильное легирование, чтобы эффективно собирать большое количество носителей заряда;\n- через коллектор протекает основной ток устройства.","height":100,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":["62bq_tkki6jhixpW-9Skc"],"versionNonce":548861343,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"zwHZW-FslHRFxSNZRdbqr","boundElements":[],"x":3140,"angle":0,"y":6000,"width":1060.0000000000002},{"seed":1613509920,"strokeStyle":"solid","id":"ELiPjNxqOkcFlavUzqQfU","strokeWidth":1,"roughness":0,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491313,"locked":false,"text":"База – это очень тонкий слой полупроводника, расположенный между эмиттером и коллектором.\n\nОсобенности:\n- имеет малую толщину (обычно несколько микрометров);\n- легируется слабее, чем эмиттер, чтобы большая часть носителей, поступающих из эмиттера, не успевала рекомбинировать и могла пройти дальше;\n- выполняет функцию контроля тока между эмиттером и коллектором. Путем изменения тока в базе можно управлять током между эмиттером и коллектором.","version":346,"autoResize":false,"type":"text","backgroundColor":"#ffffff","index":"b96zzza","roundness":null,"containerId":null,"originalText":"База – это очень тонкий слой полупроводника, расположенный между эмиттером и коллектором.\n\nОсобенности:\n- имеет малую толщину (обычно несколько микрометров);\n- легируется слабее, чем эмиттер, чтобы большая часть носителей, поступающих из эмиттера, не успевала рекомбинировать и могла пройти дальше;\n- выполняет функцию контроля тока между эмиттером и коллектором. Путем изменения тока в базе можно управлять током между эмиттером и коллектором.","height":120,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":["62bq_tkki6jhixpW-9Skc"],"versionNonce":580122577,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"zwHZW-FslHRFxSNZRdbqr","boundElements":[],"x":2580,"angle":0,"y":6120,"width":1620.0000000000002},{"isDeleted":true,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":0,"groupIds":[],"index":"b96zzzl","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":1,"version":105,"roundness":{"type":3},"type":"rectangle","updated":1782160491313,"id":"epw2t9HnMFwL3yejwnQlw","x":4240,"seed":196366624,"boundElements":[],"y":5840,"opacity":100,"height":420,"width":1019.9999999999999,"frameId":"zwHZW-FslHRFxSNZRdbqr","strokeStyle":"solid","versionNonce":2057628095},{"seed":1311466784,"strokeStyle":"solid","id":"GdVIpYwT7bw06o7xdLFJW","strokeWidth":1,"roughness":0,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491313,"locked":false,"text":"Гетероструктура – структура из разных полупроводниковых материалов. Используется для улучшения скорости, подвижности\nносителей и частотных свойств.","version":92,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"b96zzzz","roundness":null,"containerId":null,"originalText":"Гетероструктура – структура из разных полупроводниковых материалов. Используется для улучшения скорости, подвижности носителей и частотных свойств.","height":40,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":499570097,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"zwHZW-FslHRFxSNZRdbqr","boundElements":[],"x":4260,"angle":0,"y":6020,"width":980.00000000000034},{"seed":1624324320,"strokeStyle":"solid","id":"lKa6Lm5kEDGwkKyl8KaX4","strokeWidth":1,"roughness":0,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491313,"locked":false,"text":"Прямое смещение – режим, при котором p-n переход легче пропускает ток.","version":90,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"b96zzzzl","roundness":null,"containerId":null,"originalText":"Прямое смещение – режим, при котором p-n переход легче пропускает ток.","height":20,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":654268895,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"zwHZW-FslHRFxSNZRdbqr","boundElements":[],"x":4260,"angle":0,"y":5940,"width":979.99999999999977},{"seed":69520672,"strokeStyle":"solid","id":"uTAtI4Pf6BtU-dPlxgGrw","strokeWidth":1,"roughness":0,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491313,"locked":false,"text":"Носители заряда – частицы или квазичастицы, за счёт которых возникает электрический ток в полупроводнике. Основные\nносители: электроны и дырки.","version":82,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"b96zzzzt","roundness":null,"containerId":null,"originalText":"Носители заряда – частицы или квазичастицы, за счёт которых возникает электрический ток в полупроводнике. Основные носители: электроны и дырки.","height":40,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1319303057,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"zwHZW-FslHRFxSNZRdbqr","boundElements":[],"x":4260,"angle":0,"y":5860,"width":979.99999999999966},{"seed":1253815520,"strokeStyle":"solid","id":"Vt6MgxPh--3HEKQu-UmZA","strokeWidth":1,"roughness":0,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491313,"locked":false,"text":"Обеднённая область – зона возле p-n перехода, где мало свободных носителей заряда. Она может сужать или перекрывать\nпроводящий канал.","version":81,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"b96zzzzx","roundness":null,"containerId":null,"originalText":"Обеднённая область – зона возле p-n перехода, где мало свободных носителей заряда. Она может сужать или перекрывать проводящий канал.","height":40,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":450283007,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"zwHZW-FslHRFxSNZRdbqr","boundElements":[],"x":4260,"angle":0,"y":5900,"width":979.99999999999966},{"seed":852157728,"strokeStyle":"solid","id":"u7LSDzteLdO-6YNVnPAXl","strokeWidth":1,"roughness":0,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491313,"locked":false,"text":"Обратное смещение – режим, при котором p-n переход в основном запирается и почти не пропускает ток.","version":74,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"b96zzzzz","roundness":null,"containerId":null,"originalText":"Обратное смещение – режим, при котором p-n переход в основном запирается и почти не пропускает ток.","height":20,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":929029489,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"zwHZW-FslHRFxSNZRdbqr","boundElements":[],"x":4260,"angle":0,"y":5960,"width":979.99999999999977},{"seed":385511712,"strokeStyle":"solid","id":"6JLDX5YrJSI1GoOetCxFm","strokeWidth":1,"roughness":0,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491313,"locked":false,"text":"Подвижность носителей – показатель того, насколько легко электроны или дырки движутся в материале под действием\nэлектрического поля.","version":85,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"b96zzzzzV","roundness":null,"containerId":null,"originalText":"Подвижность носителей – показатель того, насколько легко электроны или дырки движутся в материале под действием электрического поля.","height":40,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1428925983,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"zwHZW-FslHRFxSNZRdbqr","boundElements":[],"x":4260,"angle":0,"y":5980,"width":979.99999999999989},{"seed":1090040032,"strokeStyle":"solid","id":"u04NFi6z_KJlXQiFtHiEM","strokeWidth":1,"roughness":0,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491313,"locked":false,"text":"Туннелирование – квантовый эффект, при котором носитель заряда проходит через энергетический барьер, который в\nклассической модели был бы непроходим.","version":84,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"b96zzzzzl","roundness":null,"containerId":null,"originalText":"Туннелирование – квантовый эффект, при котором носитель заряда проходит через энергетический барьер, который в классической модели был бы непроходим.","height":40,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":658835281,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"zwHZW-FslHRFxSNZRdbqr","boundElements":[],"x":4260,"angle":0,"y":6060,"width":979.99999999999966},{"seed":679767264,"strokeStyle":"solid","id":"kYvwaKHX6B83Vozhr0rVN","strokeWidth":1,"roughness":0,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491313,"locked":false,"text":"Ферроэлектрическая поляризация — устойчивое электрическое состояние материала, которое может сохраняться после\nснятия внешнего поля.","version":85,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"b96zzzzzt","roundness":null,"containerId":null,"originalText":"Ферроэлектрическая поляризация — устойчивое электрическое состояние материала, которое может сохраняться после снятия внешнего поля.","height":40,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":552505919,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"zwHZW-FslHRFxSNZRdbqr","boundElements":[],"x":4260,"angle":0,"y":6100,"width":979.99999999999955},{"seed":2110387488,"strokeStyle":"solid","id":"fNCHludG5RaDgTG-zijde","strokeWidth":1,"roughness":0,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491313,"locked":false,"text":"Спин электрона – внутреннее квантовое свойство электрона, похожее на собственный угловой момент. В спинтронике\nиспользуется как дополнительный носитель информации.","version":117,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"b96zzzzzv","roundness":null,"containerId":null,"originalText":"Спин электрона – внутреннее квантовое свойство электрона, похожее на собственный угловой момент. В спинтронике используется как дополнительный носитель информации.","height":40,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":413791537,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"zwHZW-FslHRFxSNZRdbqr","boundElements":[],"x":4260,"angle":0,"y":6140,"width":980.00000000000023},{"seed":332623072,"strokeStyle":"solid","id":"ueY24gu93zkYBL9OmfQM4","strokeWidth":1,"roughness":0,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491313,"locked":false,"text":"Спинтроника – направление электроники, где используют не только заряд электрона, но и его спин.","version":111,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"b96zzzzzx","roundness":null,"containerId":null,"originalText":"Спинтроника – направление электроники, где используют не только заряд электрона, но и его спин.","height":20,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":385872479,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"zwHZW-FslHRFxSNZRdbqr","boundElements":[],"x":4260,"angle":0,"y":6180,"width":980.00000000000011},{"seed":1460556064,"strokeStyle":"solid","id":"melbVE86Xh7ewjGfATprG","strokeWidth":1,"roughness":0,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491313,"locked":false,"text":"Квантовый предел – область, где поведение устройства уже нельзя объяснить только классической электроникой;\nстановятся важны отдельные электроны, туннелирование и квантовые состояния.","version":113,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"b96zzzzzz","roundness":null,"containerId":null,"originalText":"Квантовый предел – область, где поведение устройства уже нельзя объяснить только классической электроникой; становятся важны отдельные электроны, туннелирование и квантовые состояния.","height":40,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1324754705,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"zwHZW-FslHRFxSNZRdbqr","boundElements":[],"x":42