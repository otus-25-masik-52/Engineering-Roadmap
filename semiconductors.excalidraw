    {
      "id": "2zN4h1t7xpzx0-NlHApJy",
      "type": "text",
      "x": 5605,
      "y": -1490,
      "width": 741.279296875,
      "height": 120,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
