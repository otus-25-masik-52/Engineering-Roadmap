1 0 1, где: 1 = переход сработал; 0 = переход не сработал.\n\nСостоит из набора триггеров; логики сдвига; входа нового бита. (т.к. это shift register)","height":80,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1597252447,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":6905,"angle":0,"y":-1530,"width":787.2154541015625},{"seed":1847566033,"strokeStyle":"solid","id":"S_SHAiyCzTJLgvwIXpCfH","strokeWidth":1,"roughness":1,"isDeleted":true,"startBinding":{"mode":"orbit","fixedPoint":[0,0.50009999999999999],"elementId":"fHdPDfgAHOnRtH6jiLEvO"},"endArrowhead":"arrow","opacity":100,"updated":1782160485834,"locked":false,"points":[[0,0],[-89.004129036882659,-169.10778204973758]],"version":289,"moveMidPointsWithElement":false,"elbowed":false,"type":"arrow","backgroundColor":"transparent","index":"b0ZzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzV","roundness":{"type":2},"height":169.10778204973758,"link":null,"startArrowhead":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"endBinding":{"mode":"orbit","fixedPoint":[1,0.50009999999999999],"elementId":"suNuMfS7OZwVh1aXpfBkm"},"versionNonce":2014938641,"frameId":null,"boundElements":[],"x":6894.5,"angle":0,"y":-1500.4403299999985,"width":89.004129036882659},{"isDeleted":true,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":[],"index":"b0Zzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzl","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":1,"version":325,"roundness":null,"type":"rectangle","updated":1782160485834,"id":"vabNbZD9WwcA9cR_F8_MC","x":5600,"seed":622469681,"boundElements":[],"y":-1500,"opacity":100,"height":140,"width":800,"frameId":null,"strokeStyle":"solid","versionNonce":1421238143},{"seed":2140177265,"strokeStyle":"solid","id":"2zN4h1t7xpzx0-NlHApJy","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"middle","updated":1782160485834,"locked":false,"text":"Логика вокруг call и ret, т.е. это не сама “память адресов возврата”, а управляющий механизм:\nувидели call -> обновить RAS\nувидели ret -> взять адрес из RAS\n\nСостоит из: логики распознавания call\/ret; управления RAS; взаимодействия с BTB; логики\nисправления ошибок.","version":310,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b0Zzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzp","roundness":null,"containerId":"vabNbZD9WwcA9cR_F8_MC","originalText":"Логика вокруг call и ret, т.е. это не сама “память адресов возврата”, а управляющий механизм:\nувидели call -> обновить RAS\nувидели ret -> взять адрес из RAS\n\nСостоит из: логики распознавания call\/ret; управления RAS; взаимодействия с BTB; логики исправления ошибок.","height":120,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1073781745,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":5605,"angle":0,"y":-1490,"width":741.279296875},{"seed":1567093535,"strokeStyle":"solid","id":"OA0P2zR3MDM-t0fxbzCeK","strokeWidth":1,"roughness":1,"isDeleted":true,"startBinding":{"mode":"orbit","fixedPoint":[1,0.50009999999999999],"elementId":"vabNbZD9WwcA9cR_F8_MC"},"endArrowhead":"arrow","opacity":100,"updated":1782160485834,"locked":false,"points":[[0,0],[88.999999999999091,-151.30889999999943]],"version":285,"moveMidPointsWithElement":false,"elbowed":false,"type":"arrow","backgroundColor":"transparent","index":"b0Zzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzt","roundness":{"type":2},"height":151.30889999999943,"link":null,"startArrowhead":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"endBinding":{"mode":"orbit","fixedPoint":[0,0.50009999999999999],"elementId":"6OuOsabCfRYX9f8LB42h0"},"versionNonce":853284767,"frameId":null,"boundElements":[],"x":6405.5000000000009,"angle":0,"y":-1439.3365500000018,"width":88.999999999999091},{"isDeleted":true,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":[],"index":"b0Zzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzx","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":1,"version":267,"roundness":null,"type":"rectangle","updated":1782160485834,"id":"A0WsezNSeTdulmkHnoPRw","x":6900,"seed":2138136241,"boundElements":[],"y":-1420,"opacity":100,"height":180,"width":799.99999999999989,"frameId":null,"strokeStyle":"solid","versionNonce":172619217},{"seed":365713311,"strokeStyle":"solid","id":"6gC6060V6DIhrGvi2jHi8","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"middle","updated":1782160485834,"locked":false,"text":"Логика, которая срабатывает, когда ядро угадало путь неправильно. Ядро подумало: \"пойдём на\n0x1010\", а потом выяснилось: \"нет, надо было идти на 0x1008\", тогда надо:\n1. выкинуть ошибочно выбранные инструкции;\n2. восстановить правильное состояние;\n3. отправить front-end на правильный адрес.\n\nСостоит из: сигналов flush; логики отмены wrong-path инструкций; логики восстановления\ncheckpoint'ов; генерации redirect address.","version":299,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b0Zzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzy","roundness":null,"containerId":"A0WsezNSeTdulmkHnoPRw","originalText":"Логика, которая срабатывает, когда ядро угадало путь неправильно. Ядро подумало: \"пойдём на 0x1010\", а потом выяснилось: \"нет, надо было идти на 0x1008\", тогда надо:\n1. выкинуть ошибочно выбранные инструкции;\n2. восстановить правильное состояние;\n3. отправить front-end на правильный адрес.\n\nСостоит из: сигналов flush; логики отмены wrong-path инструкций; логики восстановления checkpoint'ов; генерации redirect address.","height":160,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":265669567,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":6905,"angle":0,"y":-1410,"width":754.9112548828125},{"seed":418345663,"strokeStyle":"solid","id":"8_7P_Srk9XrhHTly7klfb","strokeWidth":1,"roughness":1,"isDeleted":true,"startBinding":{"mode":"orbit","fixedPoint":[0,0.50009999999999999],"elementId":"A0WsezNSeTdulmkHnoPRw"},"endArrowhead":"arrow","opacity":100,"updated":1782160485834,"locked":false,"points":[[0,0],[-89.00413570209821,-169.11492376573875]],"version":314,"moveMidPointsWithElement":false,"elbowed":false,"type":"arrow","backgroundColor":"transparent","index":"b0Zzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzz","roundness":{"type":2},"height":169.11492376573875,"link":null,"startArrowhead":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"endBinding":{"mode":"orbit","fixedPoint":[1,0.50009999999999999],"elementId":"LvPQFlszEZ_1eKNOzSqQT"},"versionNonce":1510806449,"frameId":null,"boundElements":[],"x":6894.5000000000018,"angle":0,"y":-1340.4327699999976,"width":89.00413570209821},{"isDeleted":true,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":[],"index":"b0ZzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzV","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":1,"version":307,"roundness":null,"type":"rectangle","updated":1782160485834,"id":"7gVJT0X1SpZEuqLADtrha","x":5600,"seed":1083443263,"boundElements":[],"y":-1340,"opacity":100,"height":260,"width":800,"frameId":null,"strokeStyle":"solid","versionNonce":1740897247},{"seed":1401476159,"strokeStyle":"solid","id":"lyCQDO7s_DLSoMNc4CY6d","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"middle","updated":1782160485834,"locked":false,"text":"Логика, которая сохраняет состояние “на всякий случай”, пока ядро идёт по предсказанному пути.\nПроще: Это save point в игре. Перед тем как пойти по предположительному пути, ядро может\nсохранить:\n- \"а что было в истории переходов?\"\n- \"а что было в RAS?\"\n- \"какой был PC?\"\n- \"какое было состояние predictor'а?\"\n\nЕсли предсказание неверное – можно откатиться.\n\nСостоит из: небольших записей checkpoint'ов; регистров\/буферов; логики save\/restore; индексов\nсвязи с конкретным переходом.","version":305,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b0Zzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzd","roundness":null,"containerId":"7gVJT0X1SpZEuqLADtrha","originalText":"Логика, которая сохраняет состояние “на всякий случай”, пока ядро идёт по предсказанному пути. Проще: Это save point в игре. Перед тем как пойти по предположительному пути, ядро может сохранить:\n- \"а что было в истории переходов?\"\n- \"а что было в RAS?\"\n- \"какой был PC?\"\n- \"какое было состояние predictor'а?\"\n\nЕсли предсказание неверное – можно откатиться.\n\nСостоит из: небольших записей checkpoint'ов; регистров\/буферов; логики save\/restore; индексов связи с конкретным переходом.","height":240,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1668380049,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":5605,"angle":0,"y":-1330,"width":773.07135009765625},{"seed":612163537,"strokeStyle":"solid","id":"EPkhfZNKNG7CWxmp1Mkxe","strokeWidth":1,"roughness":1,"isDeleted":true,"startBinding":{"mode":"orbit","fixedPoint":[1,0.50009999999999999],"elementId":"7gVJT0X1SpZEuqLADtrha"},"endArrowhead":"arrow","opacity":100,"updated":1782160485834,"locked":false,"points":[[0,0],[89.119897328065235,-204.9946711882975]],"version":321,"moveMidPointsWithElement":false,"elbowed":false,"type":"arrow","backgroundColor":"transparent","index":"b0Zzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzl","roundness":{"type":2},"height":204.9946711882975,"link":null,"startArrowhead":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"endBinding":{"mode":"orbit","fixedPoint":[0,0.50009999999999999],"elementId":"6xiSwfnjvtp-G5Z5lk4AF"},"versionNonce":1589061631,"frameId":null,"boundElements":[],"x":6405.5000000000009,"angle":0,"y":-1222.6252100000002,"width":89.119897328065235},{"isDeleted":true,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":[],"index":"b0Zzzzzzzzzzzzzzzzzzzz