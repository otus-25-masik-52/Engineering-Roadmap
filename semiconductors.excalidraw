1e","fillStyle":"solid","groupIds":[],"versionNonce":1511085791,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1961.4001159667969,"angle":0,"y":1425,"width":277.19976806640625},{"isDeleted":true,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":[],"index":"b0VzzzzzzzzzzzzzzW4","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":1,"version":174,"roundness":{"type":3},"type":"rectangle","updated":1782160491311,"id":"b-56JebN6Eubom6fA3b3i","x":1640,"seed":1729362452,"boundElements":[],"y":1420,"opacity":100,"height":100,"width":280,"frameId":"wOzEezyojffBefVHAZ87N","strokeStyle":"dashed","versionNonce":192629393},{"seed":429283220,"strokeStyle":"solid","id":"VE45W_o94029w9-z5NlNC","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491311,"locked":false,"text":"Специальные \/ функциональные","version":170,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b0VzzzzzzzzzzzzzzW8","roundness":null,"containerId":"b-56JebN6Eubom6fA3b3i","originalText":"Специальные \/ функциональные","height":20,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1956717311,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1657.1760940551758,"angle":0,"y":1425,"width":245.64781188964844},{"seed":1480153477,"strokeStyle":"solid","id":"a57vMxHLrmQY_i2ZwCtcK","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":28,"opacity":100,"verticalAlign":"top","updated":1782160491311,"locked":false,"text":"Транзисторы","version":298,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b0VzzzzzzzzzzzzzzWG","roundness":null,"containerId":null,"originalText":"Транзисторы","height":35,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":2075512945,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"wOzEezyojffBefVHAZ87N","boundElements":[],"x":1620,"angle":0,"y":-885,"width":175.81192016601562},{"isDeleted":true,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":["jDLfwoqsk2iAGDOshCMmo"],"index":"b0VzzzzzzzzzzzzzzWO","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":1,"version":331,"roundness":{"type":3},"type":"rectangle","updated":1782160491311,"id":"m-2zK75tFJCpf74gxCJuJ","x":2300,"seed":742099461,"boundElements":[],"y":-840,"opacity":100,"height":120,"width":680,"frameId":"wOzEezyojffBefVHAZ87N","strokeStyle":"solid","versionNonce":530737951},{"seed":1809286059,"strokeStyle":"solid","id":"ER4lcBSfu2j_4YCBnKV3V","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491311,"locked":false,"text":"MOSFET (Metal-Oxide-Semiconductor Field-Effect Transistor) – это полевой\nтранзистор с изолированным затвором. (MOSFET = MOS-транзистор)","version":371,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"b0VzzzzzzzzzzzzzzWV","roundness":null,"containerId":null,"originalText":"MOSFET (Metal-Oxide-Semiconductor Field-Effect Transistor) – это полевой транзистор с изолированным затвором. (MOSFET = MOS-транзистор)","height":40,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":["jDLfwoqsk2iAGDOshCMmo"],"versionNonce":1919195729,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"wOzEezyojffBefVHAZ87N","boundElements":[],"x":2320,"angle":0,"y":-780,"width":640},{"seed":1217380459,"strokeStyle":"solid","id":"9KgcFDOn_DFKhjy-iLSDl","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1782160491311,"locked":false,"text":"MOSFET","version":292,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b0VzzzzzzzzzzzzzzWd","roundness":null,"containerId":null,"originalText":"MOSFET","height":25,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":["jDLfwoqsk2iAGDOshCMmo"],"versionNonce":1199943487,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"wOzEezyojffBefVHAZ87N","boundElements":[],"x":2320,"angle":0,"y":-820,"width":87.599960327148438},{"seed":1170546533,"strokeStyle":"solid","id":"riA6ZWtsiChSxwoMxwT47","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1782160491311,"locked":false,"text":"Принцип работы MOSFET","version":399,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b0VzzzzzzzzzzzzzzWl","roundness":null,"containerId":null,"originalText":"Принцип работы MOSFET","height":25,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":["7s0y54W53n5m7y5MvcJ9S"],"versionNonce":543107121,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"wOzEezyojffBefVHAZ87N","boundElements":[],"x":2320,"angle":0,"y":220,"width":248.69985961914062},{"isDeleted":true,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":["7s0y54W53n5m7y5MvcJ9S"],"index":"b0VzzzzzzzzzzzzzzWt","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":1,"version":379,"roundness":{"type":3},"type":"rectangle","updated":1782160491311,"id":"d9Xu4EDh_Zpxk3v8TC58n","x":2300,"seed":756483749,"boundElements":[],"y":200,"opacity":100,"height":240,"width":680,"frameId":"wOzEezyojffBefVHAZ87N","strokeStyle":"solid","versionNonce":1990946655},{"seed":239201707,"strokeStyle":"solid","id":"Lyl4JYc5-H_Gqt2piF2OP","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491311,"locked":false,"text":"1. На затвор подают напряжение относительно истока.\n2. Через изолятор возникает электрическое поле.\n3. Поле “перестраивает” носители заряда в кремнии под затвором.\n4. Если поле достаточно сильное, появляется канал между истоком и стоком.\n5. И уже через этот канал может течь ток.","version":427,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"b0VzzzzzzzzzzzzzzX","roundness":null,"containerId":null,"originalText":"1. На затвор подают напряжение относительно истока.\n2. Через изолятор возникает электрическое поле.\n3. Поле “перестраивает” носители заряда в кремнии под затвором.\n4. Если поле достаточно сильное, появляется канал между истоком и стоком.\n5. И уже через этот канал может течь ток.","height":100,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":["7s0y54W53n5m7y5MvcJ9S"],"versionNonce":797768209,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"wOzEezyojffBefVHAZ87N","boundElements":[],"x":2320,"angle":0,"y":260,"width":640.00000000000023},{"seed":1092067531,"strokeStyle":"solid","id":"z4Nyi4K0eqUVh65Ydo52K","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491311,"locked":false,"text":"MOSFET поэтому и называется полевым транзистором: проводимость канала\nуправляется полем от изолированного затвора.","version":392,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"b0VzzzzzzzzzzzzzzX4","roundness":null,"containerId":null,"originalText":"MOSFET поэтому и называется полевым транзистором: проводимость канала управляется полем от изолированного затвора.","height":40,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":["7s0y54W53n5m7y5MvcJ9S"],"versionNonce":392440703,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"wOzEezyojffBefVHAZ87N","boundElements":[],"x":2320,"angle":0,"y":380,"width":640},{"seed":997920773,"strokeStyle":"solid","id":"rrG18plqd9B3MAR3awmnZ","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491311,"locked":false,"text":"У MOSFET обычно выделяют четыре вывода\/области: затвор (gate), исток\n(source), сток (drain) и тело\/подложку (bulk \/ body).","version":389,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"b0VzzzzzzzzzzzzzzX8","roundness":null,"containerId":null,"originalText":"У MOSFET обычно выделяют четыре вывода\/области: затвор (gate), исток (source), сток (drain) и тело\/подложку (bulk \/ body).","height":40,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":["hcVEB05z9p17XyJt1bIwf"],"versionNonce":551915505,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"wOzEezyojffBefVHAZ87N","boundElements":[],"x":2320,"angle":0,"y":-640,"width":640},{"isDeleted":true,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":["hcVEB05z9p17XyJt1bIwf"],"index":"b0VzzzzzzzzzzzzzzXG","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":1,"version":362,"roundness":{"type":3},"type":"rectangle","updated":1782160491311,"id":"5hKnDhhOfd1UHdNIZ3qPy","x":2300,"seed":1078221797,"boundElements":[],"y":-700,"opacity":100,"height":880,"width":680,"frameId":"wOzEezyojffBefVHAZ87N","strokeStyle":"solid","versionNonce":1978688415},{"seed":1733228971,"strokeStyle":"solid","id":"dEAcrMbxEoG0M8hJJzy44","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1782160491311,"locked":false,"text":"Устройство MOSFET","version":320,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b0VzzzzzzzzzzzzzzXO","roundness":null,"containerId":null,"originalText":"Устройство MOSFET","height":25,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":["hcVEB05z9p17XyJt1bIwf"],"versionNonce":1785752017,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"wOzEezyojffBefVHAZ87N","boundElements":[],"x":2320,"angle":0,"y":-680,"width":200.95991516113281},{"seed":234493931,"strokeStyle":"solid","id":"UVVH0MkUadfjRWETt3WCW","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491311,"locked":false,"text":"1. Gate (затвор) – это проводящая управляющая пластина над каналом\nтранзистора. Он управляет \"включением\/отключением\" канала между истоком и\nстоком: при росте напряжения затвора возникает электрическое поле, которое\nпритягивает электроны к области под тонким оксидом, и при достаточном\nнапряжении появляется проводящий канал между истоком и стоком.\n\nВ ранних MOS-транзисторах затвор мог быть металлическим, отсюда первая\nбуква M в MOS: Metal–Oxide–Semiconductor.\n\nПотом в массовой CMOS-технологии долго использовали поликристаллический\nкремний, или polysilicon \/ poly-Si. То есть затвор был сделан из отдельного\nпроводящего слоя поликремния, обычно сильно легированного, чтобы он хорошо\nпроводил ток.\n\nВ современных CPU Gate обычно не просто “металл” одной пластинкой, а\nсложный стек проводящих слоёв над диэлектриком затвора.","version":456,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"b0VzzzzzzzzzzzzzzXV","roundness":null,"containerId":null,"originalText":"1. Gate (затвор) – это проводящая управляющая пластина над каналом транзистора. Он управляет \"включением\/отключением\" канала между истоком и стоком: при росте напряжения затвора возникает электрическое поле, которое притягивает электроны к области под тонким оксидом, и при достаточном напряжении появляется проводящий канал между истоком и стоком.\n\nВ ранних MOS-транзисторах затвор мог быть металлическим, отсюда первая буква M в MOS: Metal–Oxide–Semiconductor.\n\nПотом в массовой CMOS-технологии долго использовали поликристаллический кремний, или polysilicon \/ poly-Si. То есть затвор был сделан из отдельного проводящего слоя поликремния, обычно сильно легированного, чтобы он хорошо проводил ток.\n\nВ современных CPU Gate обычно не просто “металл” одной пластинкой, а сложный стек проводящих слоёв над диэлектриком затвора.","height":320,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":["hcVEB05z9p17XyJt1bIwf"],"versionNonce":41981887,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"wOzEezyojffBefVHAZ87N","boundElements":[],"x":2320,"angle":0,"y":-580,"width":640},{"seed":354170981,"strokeStyle":"solid","id":"-QZ9JJt4ysrgf7-QtrSzI","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491311,"locked":false,"text":"1.1. Изолятор (диэлектрик) – тонкий слой прямо между затвором и кремнием. Он\nнужен, чтобы не дать току напрямую течь из затвора в кремний, но позволить\nэлектрическому полю затвора влиять на кремний под ним.\n\nВ учебной модели MOS-транзистора изолятор между затвором и\nполупроводником обычно называют оксидом затвора. Классический материал –\nдиоксид кремния SiO₂. Он получается как тонкий слой оксида на поверхности\nкремния.\n\nВ более современных процессорах вместо обычного SiO₂ часто используют\nматериалы с большей диэлектрической проницаемостью, например соединения на\nоснове гафния (HfO₂), потому что при очень малых размерах обычный SiO₂ стал\nбы слишком “дырявым” для тока утечки. Такие изоляторы называются high-k\nизоляторы.","version":414,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"b0VzzzzzzzzzzzzzzXd","roundness":null,"containerId":null,"originalText":"1.1. Изолятор (диэлектрик) – тонкий слой прямо между затвором и кремнием. Он нужен, чтобы не дать току напрямую течь из затвора в кремний, но позволить электрическому полю затвора влиять на кремний под ним.\n\nВ учебной модели MOS-транзистора изолятор между затвором и полупроводником обычно называют оксидом затвора. Классический материал – диоксид кремния SiO₂. Он получается как тонкий слой оксида на поверхности кремния.\n\nВ более современных процессорах вместо обычного SiO₂ часто используют материалы с большей диэлектрической проницаемостью, например соединения на основе гафния (HfO₂), потому что при очень малых размерах обычный SiO₂ стал бы слишком “дырявым” для тока утечки. Такие изоляторы называются high-k изоляторы.","height":280,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":["hcVEB05z9p17XyJt1bIwf"],"versionNonce":1430587313,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"wOzEezyojffBefVHAZ87N","boundElements":[],"x":2320,"angle":0,"y":-240,"width":639.99999999999989},{"seed":1429117093,"strokeStyle":"solid","id":"C6oZjR2bKbUiL5RNuhOSH","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491311,"locked":false,"text":"2. Bulk \/ Body (подложка \/ тело) – это полупроводниковая область, в которой\nсделан конкретный транзистор или группа транзисторов.","version":328,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"b0VzzzzzzzzzzzzzzXl","roundness":null,"containerId":null,"originalText":"2. Bulk \/ Body (подложка \/ тело) – это полупроводниковая область, в которой сделан конкретный транзистор или группа транзисторов.","height":40,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":["hcVEB05z9p17XyJt1bIwf"],"versionNonce":1396000735,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"wOzEezyojffBefVHAZ87N","boundElements":[],"x":2320,"angle":0,"y":60,"width":640.00000000000011},{"seed":1187560965,"strokeStyle":"solid","id":"I6E7NSaXVYAxwVfSOVSoo","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491311,"locked":false,"text":"3. Source (исток) и Drain (сток) – это сильно легированные области, встроенные\nв тело транзистора.","version":331,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"b0VzzzzzzzzzzzzzzXt","roundness":null,"containerId":null,"originalText":"3. Source (исток) и Drain (сток) – это сильно легированные области, встроенные в тело транзистора.","height":40,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":["hcVEB05z9p17XyJt1bIwf"],"versionNonce":462088593,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"wOzEezyojffBefVHAZ87N","boundElements":[],"x":2320,"angle":0,"y":120,"width":640},{"seed":901685643,"strokeStyle":"solid","id":"kcH2ehUvd