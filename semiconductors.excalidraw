    {
      "id": "40LjOEIJS_g02KUchl-ch",
      "type": "text",
      "x": 2085,
      "y": 3920,
      "width": 415.5676574707031,
      "height": 60,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#f8f1ee",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "iL9-IimLqGk6Y5Nr77Omf"
      ],
