    },
    {
      "id": "ikEQmissxiGNjfm7y4mVY",
      "type": "text",
      "x": 640,
      "y": -320,
      "width": 453.5837097167969,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "c1muQITFfv8kHFk7uEVJi"
      ],
      "frameId": "abfpzohTRiR-xsawwguyo",
      "index": "a6K",
      "roundness": null,
      "seed": 849542757,
      "version": 329,
      "versionNonce": 1997981375,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1782160585804,
      "link": null,
      "locked": false,
      "text": "Если мы добавим: бор или алюминий или галлий или индий",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Если мы добавим: бор или алюминий или галлий или индий",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "CGzll97I7Vo9dYc9HJ3vi",
      "type": "text",
      "x": 640,
      "y": -120,
      "width": 820,
      "height": 80,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "c1muQITFfv8kHFk7uEVJi"
      ],
      "frameId": "abfpzohTRiR-xsawwguyo",
      "index": "a6Q",
      "roundness": null,
      "seed": 1826613701,
      "version": 682,
      "versionNonce": 1068320945,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1782160585804,
      "link": null,
      "locked": false,
      "text": "то на выходе получим атом-примесь с 3 валентными электронами: для 4-й связи не хватает электрона,\nпоэтому появляется дырка и электрон из соседней связи может перескочить и “закрыть” дырку, но тогда\nдырка появляется там, откуда он ушёл. Физически двигаются электроны, но описывать это удобно так,\nбудто движется положительная дырка, отсюда и название P-type (от слова positive).",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "то на выходе получим атом-примесь с 3 валентными электронами: для 4-й связи не хватает электрона, поэтому появляется дырка и электрон из соседней связи может перескочить и “закрыть” дырку, но тогда дырка появляется там, откуда он ушёл. Физически двигаются электроны, но описывать это удобно так, будто движется положительная дырка, отсюда и название P-type (от слова positive).",
      "autoResize": false,
      "lineHeight": 1.25
    },
