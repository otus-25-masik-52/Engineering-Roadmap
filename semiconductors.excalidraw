620,"seed":1717199723,"boundElements":[],"y":-400,"opacity":100,"height":440,"width":320,"frameId":"wOzEezyojffBefVHAZ87N","strokeStyle":"solid","versionNonce":591272991},{"seed":1351329637,"strokeStyle":"solid","id":"-Wtujws9Dt2TXKUZfisAG","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1782160491311,"locked":false,"text":"nMOS","version":307,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b0VzzzzzzzzzzzzzzYG","roundness":null,"containerId":null,"originalText":"nMOS","height":25,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":["poNaHIcy88UNRUJAsxLLI"],"versionNonce":1280866641,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"wOzEezyojffBefVHAZ87N","boundElements":[],"x":1640,"angle":0,"y":-380,"width":53.619964599609375},{"seed":791171307,"strokeStyle":"solid","id":"3dBbr32jyZMPQm9t6UGMM","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491311,"locked":false,"text":"В цифровых схемах nMOS обычно\nиспользуется для соединения\nвыхода с землёй, то есть для\nполучения 0.","version":361,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"b0VzzzzzzzzzzzzzzYO","roundness":null,"containerId":null,"originalText":"В цифровых схемах nMOS обычно используется для соединения выхода с землёй, то есть для получения 0.","height":80,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":["poNaHIcy88UNRUJAsxLLI"],"versionNonce":511918143,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"wOzEezyojffBefVHAZ87N","boundElements":[],"x":1640,"angle":0,"y":-60,"width":280.00000000000011},{"seed":780248011,"strokeStyle":"solid","id":"eae9_TkNNR1YxW4tKuOau","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491311,"locked":false,"text":"Структура:\nn+ исток и n+ сток расположены в\np-type подложке.","version":317,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"b0VzzzzzzzzzzzzzzYV","roundness":null,"containerId":null,"originalText":"Структура:\nn+ исток и n+ сток расположены в p-type подложке.","height":60,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":["poNaHIcy88UNRUJAsxLLI"],"versionNonce":1853826865,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"wOzEezyojffBefVHAZ87N","boundElements":[],"x":1640,"angle":0,"y":-340,"width":280},{"seed":628533253,"strokeStyle":"solid","id":"wxhVuoBe6JMteQK3PCyV1","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491311,"locked":false,"text":"Принцип:\nесли напряжение на затворе\nдостаточно высокое относительно\nистока, под затвором появляется\nэлектронный канал.","version":348,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"b0VzzzzzzzzzzzzzzYd","roundness":null,"containerId":null,"originalText":"Принцип:\nесли напряжение на затворе достаточно высокое относительно истока, под затвором появляется электронный канал.","height":100,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":["poNaHIcy88UNRUJAsxLLI"],"versionNonce":432988255,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"wOzEezyojffBefVHAZ87N","boundElements":[],"x":1640,"angle":0,"y":-260,"width":280},{"seed":910190117,"strokeStyle":"solid","id":"7nfNKBMpj59kOHQpmvDyQ","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491311,"locked":false,"text":"Логика:\nзатвор = 1 -> открыт;\nзатвор = 0 -> закрыт.","version":314,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"b0VzzzzzzzzzzzzzzYl","roundness":null,"containerId":null,"originalText":"Логика:\nзатвор = 1 -> открыт;\nзатвор = 0 -> закрыт.","height":60,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":["poNaHIcy88UNRUJAsxLLI"],"versionNonce":1465