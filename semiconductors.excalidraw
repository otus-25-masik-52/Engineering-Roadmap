ontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491311,"locked":false,"text":"По режиму","version":140,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b0VzzzzzzzzzzzzzzVO","roundness":null,"containerId":"FcBPsuvI2-M5DqC1JVqIF","originalText":"По режиму","height":20,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":129358463,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2020.296028137207,"angle":0,"y":1785,"width":79.407943725585938},{"isDeleted":true,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":[],"index":"b0VzzzzzzzzzzzzzzVV","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":1,"version":130,"roundness":{"type":3},"type":"rectangle","updated":1782160491311,"id":"qz4R-rB86-DOEU55FS7io","x":1640,"seed":1516174124,"boundElements":[],"y":1780,"opacity":100,"height":100,"width":220.00000000000003,"frameId":"wOzEezyojffBefVHAZ87N","strokeStyle":"dashed","versionNonce":1527402737},{"seed":151654292,"strokeStyle":"dashed","id":"Qd0fjUF5ts-WOVhmbf7RB","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491311,"locked":false,"text":"По типу канала","version":132,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b0VzzzzzzzzzzzzzzVZ","roundness":null,"containerId":"qz4R-rB86-DOEU55FS7io","originalText":"По типу канала","height":20,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1848914591,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1690.3840560913086,"angle":0,"y":1785,"width":119.23188781738281},{"isDeleted":true,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":[],"index":"b0VzzzzzzzzzzzzzzVd","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":1,"version":137,"roundness":{"type":3},