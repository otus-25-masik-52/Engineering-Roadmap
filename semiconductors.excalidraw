    },
    {
      "id": "aZ8RScvN_QfGjmrCfPrSy",
      "type": "text",
      "x": 160,
      "y": -260,
      "width": 400.9435729980469,
      "height": 40,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ff8787",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "YZBr2_6nlNz0bufBdauag"
      ],
      "frameId": "abfpzohTRiR-xsawwguyo",
      "index": "a6E",
      "roundness": null,
      "seed": 981817797,
      "version": 221,
      "versionNonce": 358642335,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1782160585804,
      "link": null,
      "locked": false,
      "text": "(такие примеси называют донорами,\nпотому что они “отдают” электрон в проводимость)",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "(такие примеси называют донорами,\nпотому что они “отдают” электрон в проводимость)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "WrwVB-7aAkKlgMJu7QAnC",
