2120.0142000000001,"angle":0,"y":795.5,"width":0.007599999999911233},{"seed":120735109,"strokeStyle":"solid","id":"_V-eSW1F7d_tTY3InFAp0","strokeWidth":1,"roughness":1,"isDeleted":true,"startBinding":{"mode":"orbit","fixedPoint":[0.50009999999999999,1],"elementId":"xviYiNnS8-W_Sp2jQdurr"},"endArrowhead":"arrow","opacity":100,"updated":1782160491312,"locked":false,"points":[[0,0],[-0.007599999999911233,19]],"version":351,"moveMidPointsWithElement":false,"elbowed":false,"type":"arrow","backgroundColor":"transparent","index":"b0Vzzzzzzzzzzzzzzct","roundness":{"type":2},"height":19,"link":null,"startArrowhead":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":["RjN4e9xxDRe7Hxr_BgovN","s0aZHLOz_5r-oXXqM2rzG"],"endBinding":{"mode":"orbit","fixedPoint":[0.50009999999999999,0],"elementId":"v15m1bTnr4a9PnEmsydHt"},"versionNonce":892437681,"frameId":"wOzEezyojffBefVHAZ87N","boundElements":[],"x":2120.0218,"angle":0,"y":855.5,"width":0.007599999999911233},{"isDeleted":true,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":["gJcQFugu_nlG9ebfVj9Pe"],"index":"b0Vzzzzzzzzzzzzzzd","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":1,"version":563,"roundness":{"type":3},"type":"rectangle","updated":1782160491312,"id":"knX7qE_3Tv7VD5fAWPS4q","x":2300,"seed":955380139,"boundElements":[],"y":940,"opacity":100,"height":279.99999999999989,"width":680.00000000000023,"frameId":"wOzEezyojffBefVHAZ87N","strokeStyle":"solid","versionNonce":337320671},{"seed":1499647173,"strokeStyle":"solid","id":"bXSOzSqNtqjy3UF5C-wYK","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160491312,"locked":false,"text":"Транзистор – минимальный управляемый ключ цифровой схемы. Сам по себе он\nне выполняет вычислений: он только открывает или закрывает путь для тока.\nКогда nMOS и pMOS соединяют в CMOS-схемы, из них получают устойчивые\nлогические уровни 0 и 1. На этом уровне ток и напряжение превращаются в\nцифровую логику: NOT, NAND, NOR, AND, OR, XOR. Именно поэтому компьютер\n“думает” нулями и единицами. На физическом уровне ему удобно различать: есть\nпроводящий путь для тока или нет, низкое напряжение или высокое, логический 0\nили логическая 1. Транзисторы позволяют надёжно создавать и переключать эти\nдва состояния, а логические элементы используют их как строительные\nкирпичики для вычислений, хранения и передачи данных.","version":813,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"b0Vzzzzzzzzzzzzzzd4","roundness":{"type":2},"containerId":null,"originalText":"Транзистор – минимальный управляемый ключ цифровой схемы. Сам по себе он не выполняет вычислений: он только открывает или закрывает путь для тока. Когда nMOS и pMOS соединяют в CMOS-схемы, из них получают устойчивые логические уровни 0 и 1. На этом уровне ток и напряжение превращаются в цифровую логику: NOT, NAND, NOR, AND, OR, XOR. Именно поэтому компьютер “думает” нулями и единицами. На физическом уровне ему удобно различать: есть проводящий путь для тока или нет, низкое напряжение или высокое, логический 0 или логическая 1. Транзисторы позволяют надёжно создавать и переключать эти два состояния, а логические элементы используют их как строительные кирпичики для вычислений, хранения и передачи данных.","height":200,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":["gJcQFugu_nlG9ebfVj9Pe"],"versionNonce":585090705,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"wOzEezyojffBefVHAZ87N","boundElements":[],"x":2320,"angle":0,"y":1000,"width":640.00000000000011},{"seed":1556893323,"strokeStyle":"solid","id":"t15_71BOIPK0as2VRZhqy","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1782160491312,"locked":false,"text":"Основная идея","version":470,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b0Vzzzzzzzzzzzzzzd8","roundness":{"type":2},"containerId":null,"o