      "version": 130,
      "versionNonce": 2118713599,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1782159893980,
      "link": null,
      "locked": false,
      "text": "Полупроводники",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Полупроводники",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "fG1qkLUT8bW8szpI2-WCi",
      "type": "text",
      "x": -980,
      "y": 280,
      "width": 156.30384826660156,
      "height": 20,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "U8DV7cXTdf_dQCzWw0Ywo"
      ],
      "frameId": "2046wXhfGP72zoBJL_haM",
      "index": "b972",
      "roundness": null,
      "seed": 34646771,
      "version": 431,
      "versionNonce": 662884977,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "4YssnuLKPSZHWeez-ucqj",
          "type": "arrow"
        }
      ],
      "updated": 1782159893980,
      "link": null,
      "locked": false,
      "text": "Ядро атома кремния",
