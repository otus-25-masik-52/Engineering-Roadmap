83.9195556640625},{"seed":981475743,"strokeStyle":"solid","id":"s2sf4i-M21csvcT99wgqv","strokeWidth":1,"roughness":1,"isDeleted":true,"startBinding":{"mode":"orbit","fixedPoint":[1,0.50009999999999999],"elementId":"Td2H8RA6bFCyaVwONtYLA"},"endArrowhead":"arrow","opacity":100,"updated":1782160485834,"locked":false,"points":[[0,0],[89,-97.905339999998759]],"version":301,"moveMidPointsWithElement":false,"elbowed":false,"type":"arrow","backgroundColor":"transparent","index":"b0ZzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzV","roundness":{"type":2},"height":97.905339999998759,"link":null,"startArrowhead":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"endBinding":{"mode":"orbit","fixedPoint":[0,0.50009999999999999],"elementId":"kCWJg3SpCTgW3ZXvKCj20"},"versionNonce":1670646495,"frameId":null,"boundElements":[],"x":6405.5,"angle":0,"y":-1816.0403300000012,"width":89},{"isDeleted":true,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":[],"index":"b0Zzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzt","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":1,"version":390,"roundness":null,"type":"rectangle","updated":1782160485834,"id":"_96XJlRWYlZdqzUKjLpLo","x":6900,"seed":245468767,"boundElements":[],"y":-1780,"opacity":100,"height":220,"width":800,"frameId":null,"strokeStyle":"solid","versionNonce":1471010449},{"seed":1602320305,"strokeStyle":"solid","id":"INpCV2vbW2oDD06nReqBg","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"middle","updated":1782160485834,"locked":false,"text":"Таблица, которая хранит маленькие состояния\/счётчики для предсказания паттернов. Она пытается\nпонять: “При таком шаблоне прошлых переходов что обычно бывает дальше?” Например цикл может\nвести себя так: taken, taken, taken, taken, not taken. Часто можно представить как набор 2-битных\nсчётчиков:\n00 -> сильно не прыгать\n01 -> скорее не прыгать\n10 -> скорее прыгать\n11 -> сильно прыгать\n\nСостоит из: массива маленьких счётчиков; индексатора; логики обновления счётчика.","version":345,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b0Zzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzx","roundness":null,"containerId":"_96XJlRWYlZdqzUKjLpLo","originalText":"Таблица, которая хранит маленькие состояния\/счётчики для предсказания паттернов. Она пытается понять: “При таком шаблоне прошлых переходов что обычно бывает дальше?” Например цикл может вести себя так: taken, taken, taken, taken, not taken. Часто можно представить как набор 2-битных счётчиков:\n00 -> сильно не прыгать\n01 -> скорее не прыгать\n10 -> скорее прыгать\n11 -> сильно прыгать\n\nСостоит из: массива маленьких счётчиков; индексатора; логики обновления счётчика.","height":200,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":598562559,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":6905,"angle":0,"y":-1770,"width":787.71142578125},{"seed":129981937,"strokeStyle":"solid","id":"-Jp4OGrBqVQ2qAhcpZiEw","strokeWidth":1,"roughness":1,"isDeleted":true,"startBinding":{"mode":"orbit","fixedPoint":[0,0.50009999999999999],"elementId":"_96XJlRWYlZdqzUKjLpLo"},"endArrowhead":"arrow","opacity":100,"updated":1782160485834,"locked":false,"points":[[0,0],[-89,-151.31601999999953]],"version":282,"moveMidPointsWithElement":false,"elbowed":false,"type":"arrow","backgroundColor":"transparent","index":"b0Zzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzz","roundness":{"type":2},"height":151.31601999999953,"link":null,"startArrowhead":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"endBinding":{"mode":"orbit","fixedPoint":[1.0000000000000002,0.50009999999999999],"elementId":"DLWcK3cwIq89UKER78U8B"},"versionNonce":968285297,"frameId":null,"boundElements":[],"x":6894.5,"angle":0,"y":-1679.3289900000002,"width":89},{"isDeleted":true,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":[],"index":"b0ZzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzV","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":1,"version":302,"roundness":null,"type":"rectangle","updated":1782160485834,"id":"II5rBDH27q2uXLED1nw0u","x":5600,"seed":1815462577,"boundElements":[],"y":-1740,"opacity":100,"height":220,"width":800,"frameId":null,"strokeStyle":"solid","versionNonce":117972767},{"seed":572461841,"strokeStyle":"solid","id":"I1i5-odQLYfnaVXpT6QY8","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"middle","updated":1782160485834,"locked":false,"text":"Таблица, которая хранит историю не всех переходов подряд, а историю конкретных переходов.\nХранит данные для ответа на вопрос: “Как обычно ведёт себя вот этот конкретный переход?”.\nНапример:\n\n0x1024: jge 0x1038\n\nДля перехода по адресу 0x1024 таблица может хранить: taken, taken, taken, not taken.\n\nСостоит из: таблицы маленьких регистров истории; индекса по адресу инструкции; логики\nчтения\/обновления.","version":310,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b0Zzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzl","roundness":null,"containerId":"II5rBDH27q2uXLED1nw0u","originalText":"Таблица, которая хранит историю не всех переходов подряд, а историю конкретных переходов. Хранит данные для ответа на вопрос: “Как обычно ведёт себя вот этот конкретный переход?”. Например:\n\n0x1024: jge 0x1038\n\nДля перехода по адресу 0x1024 таблица может хранить: taken, taken, taken, not taken.\n\nСостоит из: таблицы маленьких регистров истории; индекса по адресу инструкции; логики чтения\/обновления.","height":200,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1684285009,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":5605,"angle":0,"y":-1730,"width":752.43133544921875},{"seed":1268117713,"strokeStyle":"solid","id":"pNmzxbQlCcAEhOuD-JAfM","strokeWidth":1,"roughness":1,"isDeleted":true,"startBinding":{"mode":"orbit","fixedPoint":[1,0.50009999999999999],"el