Fay1CY","strokeWidth":1,"roughness":1,"isDeleted":true,"startBinding":{"mode":"inside","fixedPoint":[0.99813196759351053,0.48610728587175556],"elementId":"PGWsygXiouBaB1iitVEtQ"},"endArrowhead":"arrow","opacity":100,"updated":1782160485834,"locked":false,"points":[[0,0],[95.994425925191535,115.11557933683309]],"version":924,"moveMidPointsWithElement":false,"elbowed":false,"type":"arrow","backgroundColor":"transparent","index":"b0Zzzzzzzzzzzzzzzzzzzzzzzzzzz","roundness":{"type":2},"height":115.11557933683309,"link":null,"startArrowhead":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"endBinding":{"mode":"orbit","fixedPoint":[0,0.50009999999999999],"elementId":"diYhssOhb7BnSKX7RkfNE"},"versionNonce":689062239,"frameId":null,"boundElements":[],"x":6398.5055740748085,"angle":0,"y":-2321.6671256953896,"width":95.994425925191535},{"seed":682787121,"strokeStyle":"solid","id":"V082RvLbvU8LfewnkD2nV","strokeWidth":1,"roughness":1,"isDeleted":true,"startBinding":null,"endArrowhead":"arrow","opacity":100,"updated":1782160485834,"locked":false,"points":[[0,0],[-109,24.633912736535592]],"version":421,"moveMidPointsWithElement":false,"elbowed":false,"type":"arrow","backgroundColor":"transparent","index":"b0ZzzzzzzzzzzzzzzzzzzzzzzzzzzV","roundness":{"type":2},"height":24.633912736535592,"link":null,"startArrowhead":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"endBinding":{"mode":"orbit","fixedPoint":[1.0000000000000002,0.50009999999999999],"elementId":"0SlrDIItq1EVtLK6TVogj"},"versionNonce":1496598545,"frameId":null,"boundElements":[],"x":6894.5,"angle":0,"y":-2385.8729083333337,"width":109},{"isDeleted":true,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":[],"index":"b0Zzzzzzzzzzzzzzzzzzzzzzzzzzzt","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":1,"version":285,"roundness":null,"type":"rectangle","updated":1782160485834,"id":"EAGDRz4HrD3Qkux3wbbcj","x":5600,"seed":1509674591,"boundElements":[],"y":-2660,"opacity":100,"height":260,"width":800,"frameId":null,"strokeStyle":"solid","versionNonce":958446975},{"seed":1666678001,"strokeStyle":"solid","id":"6IWnocpWaNhSxiBdsMHiv","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"middle","updated":1782160485834,"locked":false,"text":"Логическая схема, которая решает: “Какой адрес записать в PC следующим?”\n\nВарианты выбора:\nобычная инструкция -> следующий адрес = текущий адрес + длина инструкции\nусловный переход предсказан как taken -> следующий адрес = адрес перехода\ncall -> следующий адрес = адрес функции\nret -> следующий адрес = адрес возврата\nошибка предсказания -> следующий адрес = правильный адрес\nexception\/interrupt -> следующий адрес = адрес обработчика\n\nСостоит из: мультиплексоров; сумматоров; компараторов; управляющей логики; приоритетов\nисточников.","version":236,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b0Zzzzzzzzzzzzzzzzzzzzzzzzzzzx","roundness":null,"containerId":"EAGDRz4HrD3Qkux3wbbcj","originalText":"Логическая схема, которая решает: “Какой адрес записать в PC следующим?”\n\nВарианты выбора:\nобычная инструкция -> следующий адрес = текущий адрес + длина инструкции\nусловный переход предсказан как taken -> следующий адрес = адрес перехода\ncall -> следующий адрес = адрес функции\nret -> следующий адрес = адрес возврата\nошибка предсказания -> следующий адрес = правильный адрес\nexception\/interrupt -> следующий адрес = адрес обработчика\n\nСостоит из: мультиплексоров; сумматоров; компараторов; управляющей логики; приоритетов источников.","height":240,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1953701361,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":5605,"angle":0,"y":-2650,"width":716.447265625},{"isDeleted":true,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":[],"index":"b0Zzzzzzzzzzzzzzzzzzzzzzzzzzzz","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":1,"version":262,"roundness":null,"type":"rectangle","updated":1782160485834,"id":"sGqdC8UQPRbep22ZkXdAv","x":6900,"seed":747035711,"boundElements":[],"y":-2660,"opacity":100,"height":200,"width":799.99999999999989,"frameId":null,"strokeStyle":"solid","versionNonce":373994911},{"seed":1278036017,"strokeStyle":"solid","id":"L8OpVR6TxZIXRTIzHvygB","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"middle","updated":1782160485834,"locked":false,"text":"Регистр, хранящий адрес инструкции или адрес следующего места, откуда надо читать код.\n\nТаких регистров в ядре может быть несколько:\nАрхитектурно – по одному на аппаратный поток.\nЕсли ядро без SMT – обычно один активный поток, значит один основной архитектурный PC.\nЕсли ядро с SMT\/Hyper-Threading – у каждого аппаратного потока свой PC.\n\nСостоит из набора триггеров, потому что это регистр. Если адрес 64-битный, то грубо можно\nпредставить как 64 бита хранения.","version":294,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b0ZzzzzzzzzzzzzzzzzzzzzzzzzzzzV","roundness":null,"containerId":"sGqdC8UQPRbep22ZkXdAv","originalText":"Регистр, хранящий адрес инструкции или адрес следующего места, откуда надо читать код.\n\nТаких регистров в ядре может быть несколько:\nАрхитектурно – по одному на аппаратный поток.\nЕсли ядро без SMT – обычно один активный поток, значит один основной архитектурный PC.\nЕсли ядро с SMT\/Hyper-Threading – у каждого аппаратного потока свой PC.\n\nСостоит из набора триггеров, потому что это регистр. Если адрес 64-битный, то грубо можно представить как 64 бита хранения.","height":180,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1360803793,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":6905,"angle":0,"y":-2650,"width":735.34326171875},{"isDeleted":true,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":[],"index":"b0Zzzzzzzzzzzzzzzzzzzzzzzzzzzzl","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":1,"version":439,"roundness":null,"type":"rectangle","updated":1782160485834,"id":"PGWsygXiouBaB1iitVEtQ","x":5600,"seed":838853759,"boundElements":[],"y":-2380,"opacity":100,"height":120,"width":800,"frameId":null,"strokeStyle":"solid","versionNonce":130066879},{"seed":1745792273,"strokeStyle":"solid","id":"3UwbuWvIYllzNX8H5x0Lg","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"middle","updated":1782160485834,"locked":false,"text":"Подсистема, которая пытается угадать, куда программа пойдёт дальше, если впереди есть переход.\n\nТ.к. такт работы ядра очень маленький по времени, ядро не хочет ждать. Соответственно когда оно\nвидит адрес 0x1004, где раньше часто был условный переход, оно заранее пытается угадать:\nпрыгать на 0x1010 или идти дальше на 0x1008?","version":292,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b0Zzzzzzzzzzzzzzzzzzzzzzzzzzzzp","roundness":null,"containerId":"PGWsygXiouBaB1iitVEtQ","originalText":"Подсистема, которая пытается угадать, куда программа пойдёт дальше, если впереди есть переход.\n\nТ.к. такт работы ядра очень маленький по времени, ядро не хочет ждать. Соответственно когда оно видит адрес 0x1004, где раньше часто был условный переход, оно заранее пытается угадать: прыгать на 0x1010 или идти дальше на 0x1008?","height":100,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1363613105,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":5605,"angle":0,"y":-2370,"width":784.559326171875},{"isDeleted":true,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":[],"index":"b0Zzzzzzzzzzzzzzzzzzzzzzzzzzzzx","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":1,"version":403,"roundness":null,"type":"rectangle","updated":1782160485834,"id":"ONmS98jn0P6n9e3aIUHEQ","x":6900,"seed":1948760607,"boundElements":[],"y":-2440,"opacity":100,"height":280,"width":800,"frameId":null,"strokeStyle":"solid","versionNonce":446896607},{"seed":621783231,"strokeStyle":"solid","id":"XG_ohoa6iP7yU8cN0jr5n","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"middle","updated":1782160485834,"locked":false,"text":"Маленький аппаратный стек для предсказания ret. Проще: Когда программа вызывает функцию,\nнужно потом вернуться назад.\n\n0x1014: call 0x2000\n0x1019: mov i, 0\n\nПри call адрес возврата – 0x1019.\n\nRAS делает:\ncall -> положить 0x1019 в стек\nret -> достать 0x1019 из стека\n\nСостоит из маленького массива адресов; указателя вершины стека; push\/pop logic.","version":272,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b0Zzzzzzzzzzzzzzzzzzzzzzzzzzzzz","roundness":null,"containerId":"ONmS98jn0P6n9e3aIUHEQ","originalText":"Маленький аппаратный стек для предсказания ret. Проще: Когда программа вызывает функцию, нужно потом вернуться назад.\n\n0x1014: call 0x2000\n0x1019: mov i, 0\n\nПри call адрес возврата – 0x1019.\n\nRAS делает:\ncall -> положить 0x1019 в стек\nret -> достать 0x1019 из стека\n\nСостоит из маленького массива адресов; указателя вершины стека; push\/pop logic.","height":260,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":672872337,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":6905,"angle":0,"y":-2430,"width":739.43927001953125},{"isDeleted":true,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":[],"index":"b0ZzzzzzzzzzzzzzzzzzzzzzzzzzzzzV","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":1,"version":495,"roundness":null,"type":"rectangle","updated":1782160485834,"id":"hXnqz4I-ngtWlfzkM17Ie","x":6900,"seed":522009201,"boundElements":[],"y":-2140,"opacity":100,"height":180,"width":800,"frameId":null,"strokeStyle":"solid","versionNonce":1677886975},{"seed":1711742559,"strokeStyle":"solid","id":"QpEc63Ymo6oKCbSgu_Xnc","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"middle","updated":1782160485834,"locked":false,"text":"Таблица, которая хранит адреса, куда обычно прыгают переходы. Проще: Direction Predictor\nговорит: “прыгать”, а BTB говорит: “прыгать вот сюда: 0x1010”, например:\n\n0x1004: jle 0x1010\n\nBTB может хранить: адрес перехода: 0x1004; цель перехода: 0x1010\n\nBTB похож на маленький кэш: теги; адреса целей; valid bits; логика сравнения; логика замещения.","version":340,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b0Zzzzzzzzzzzzzzzzzzzzzzzzzzzzzd","roundness":null,"containerId":"hXnqz4I-ngtWlfzkM17Ie","originalText":"Таблица, которая хранит адреса, куда обычно прыгают переходы. Проще: Direction Predictor говорит: “прыгать”, а BTB говорит: “прыгать вот сюда: 0x1010”, например:\n\n0x1004: jle 0x1010\n\nBTB может хранить: адрес перехода: 0x1004; цель перехода: 0x1010\n\nBTB похож на маленький кэш: теги; адреса целей; valid bits; логика сравнения; логика замещения.","height":160,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":936385905,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":6905,"angle":0,"y":-2130,"width":772.0953369140625},{"seed":2110010001,"strokeStyle":"solid","id":"jxzPGR1X0HwhUuEY5PG2_","strokeWidth":1,"roughness":1,"isDeleted":true,"startBinding":{"mode":"orbit","fixedPoint":[0,0.50009999999999999],"elementId":"hXnqz4I-ngtWlfzkM17Ie"},"endArrowhead":"arrow","opacity":100,"updated":1782160485834,"locked":false,"points":[[0,0],[-109.00574993358714,-208.93876874999546]],"version":329,"moveMidPointsWithElement":false,"elbowed":false,"type":"arrow","backgroundColor":"transparent","index":"b0Zzzzzzzzzzzzzzzzzzzzzzzzzzzzzl","roundness":{"type":2},"height":208.93876874999546,"link":null,"startArrowhead":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"endBinding":{"mode":"orbit","fixedPoint":[1.0000000000000002,0.50009999999999999],"elementId":"AvnhpyNvUMyFoxSUSX0ju"},"versionNonce":48197151,"frameId":null,"boundElements":[],"x":6894.5,"angle":0,"y":-2060.5243083333362,"width":109.00574993358714},{"isDeleted":true,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":[],"index":"b0Zzzzzzzzzzzzzzzzzzzzzzzzzzzzzx","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":1,"version":357,"roundness":null,"type":"rectangle","updated":1782160485834,"id":"yhCA9kpazp8FC-ezU6801","x":5600,"seed":1604694513,"boundElements":[],"y":-2240,"opacity":100,"height":240,"width":800,"frameId":null,"strokeStyle":"solid","versionNonce":799885137},{"seed":95010353,"strokeStyle":"solid","id":"buwVwtTBKQcCTUNGDwDKd","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"middle","updated":1782160485834,"locked":false,"text":"Часть предсказателя переходов, которая отвечает на вопрос: “Переход сработает или нет?”\nНапример для инструкции:\n\n0x1004: jle 0x1010\n\nварианты такие:\ntaken -> перейти на 0x1010\nnot taken -> идти дальше на 0x1008\n\nСостоит из таблицы маленьких счётчиков; индексации по адресу инструкции; индексации по истории\nпереходов; логики выбора ответа taken\/not taken.","version":280,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b0Zzzzzzzzzzzzzzzzzzzzzzzzzzzzzy","roundness":null,"containerId":"yhCA9kpazp8FC-ezU6801","originalText":"Часть предсказателя переходов, которая отвечает на вопрос: “Переход сработает или нет?”\nНапример для инструкции:\n\n0x1004: jle 0x1010\n\nварианты такие:\ntaken -> перейти на 0x1010\nnot taken -> идти дальше на 0x1008\n\nСостоит из таблицы маленьких счётчиков; индексации по адресу инструкции; индексации по истории переходов; логики выбора ответа taken\/not taken.","height":220,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1646940735,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":5605,"angle":0,"y":-2230,"width":777.63140869140625},{"seed":1009479793,"strokeStyle":"solid","id":"w5Emv6oWucPO3LFZ57DAG","strokeWidth":1,"roughness":1,"isDeleted":true,"startBinding":{"mode":"orbit","fixedPoint":[1,0.50009999999999999],"elementId":"yhCA9kpazp8FC-ezU6801"},"endArrowhead":"arrow","opacity":100,"updated":1782160485834,"locked":false,"points":[[0,0],[109,-72.684833333334154]],"version":324,"moveMidPointsWithElement":false,"elbowed":false,"type":"arrow","backgroundColor":"transparent","index":"b0Zzzzzzzzzzzzzzzzzzzzzzzzzzzzzz","roundness":{"type":2},"height":72.684833333334154,"link":null,"startArrowhead":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"endBinding":{"mode":"orbit","fixedPoint":[0,0.50009999999999999],"elementId":"jzwxssxPpx37iGCIJ1bvj"},"versionNonce":1779053873,"frameId":null,"boundElements":[],"x":6405.5,"angle":0,"y":-2123.643583333333,"width":109},{"isDeleted":true,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":[],"index":"b0ZzzzzzzzzzzzzzzzzzzzzzzzzzzzzzV","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":1,"version":325,"roundness":null,"type":"rectangle","updated":1782160485834,"id":"DmLBQm8D0NIwY3mpDubYk","x":6900,"seed":1527441585,"boundElements":[],"y":-1940,"opacity":100,"height":140,"width":800,"frameId":null,"strokeStyle":"solid","versionNonce":985903711},{"seed":1038438303,"strokeStyle":"solid","id":"wiANfZdZSJjwbZldJN2X_","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"middle","updated":1782160485834,"locked":false,"text":"Блок для переходов, у которых цель заранее не записана прямо в инструкции. Например:\nОбычный переход: jmp 0x5000 (цель видна сразу: 0x5000)\nНепрямой переход: jmp rax (цель лежит в регистре rax, и она может каждый раз быть разной)\nВ C++ это часто связано с: virtual_function(); function_pointer(); switch;\n\nСостоит из: таблицы прошлых целей; истории; логики выбора наиболее вероятной цели.","version":313,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b0Zzzzzzzzzzzzzzzzzzzzzzzzzzzzzzd","roundness":null,"containerId":"DmLBQm8D0NIwY3mpDubYk","originalText":"Блок для переходов, у которых цель заранее не записана прямо в инструкции. Например:\nОбычный переход: jmp 0x5000 (цель видна сразу: 0x5000)\nНепрямой переход: jmp rax (цель лежит в регистре rax, и она может каждый раз быть разной)\nВ C++ это часто связано с: virtual_function(); function_pointer(); switch;\n\nСостоит из: таблицы прошлых целей; истории; логики выбора наиболее вероятной цели.","height":120,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":172910353,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":6905,"angle":0,"y":-1930,"width":729.34332275390625},{"seed":1006384287,"strokeStyle":"solid","id":"Kypmj5vN-nBzKB0egkUcW","strokeWidth":1,"roughness":1,"isDeleted":true,"startBinding":{"mode":"orbit","fixedPoint":[0,0.50009999999999999],"elementId":"DmLBQm8D0NIwY3mpDubYk"},"endArrowhead":"arrow","opacity":100,"updated":1782160485834,"locked":false,"points":[[0,0],[-109.03910394298691,-227.17334304086853]],"version":329,"moveMidPointsWithElement":false,"elbowed":false,"type":"arrow","backgroundColor":"transparent","index":"b0Zzzzzzzzzzzzzzzzzzzzzzzzzzzzzzl","roundness":{"type":2},"height":227.17334304086853,"link":null,"startArrowhead":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"endBinding":{"mode":"orbit","fixedPoint":[1,0.50009999999999999],"elementId":"F6pSkzQiLTkwQm0L6GMGV"},"versionNonce":1434193535,"frameId":null,"boundElements":[],"x":6894.5,"angle":0,"y":-1881.4447916666647,"width":109.03910394298691},{"isDeleted":true,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupI