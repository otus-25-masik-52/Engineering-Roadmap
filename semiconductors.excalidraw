    },
    {
      "id": "fiGOnFwu7vsG45K0xEG35",
      "type": "text",
      "x": 860,
      "y": -260,
      "width": 328.3037109375,
      "height": 40,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ff8787",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "c1muQITFfv8kHFk7uEVJi"
      ],
      "frameId": "abfpzohTRiR-xsawwguyo",
      "index": "a7j",
      "roundness": null,
      "seed": 794628843,
      "version": 174,
      "versionNonce": 1027917745,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1782160585804,
      "link": null,
      "locked": false,
      "text": "(такие примеси называют акцепторами,\nпотому что они могут “принять” электрон)",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "(такие примеси называют акцепторами,\nпотому что они могут “принять” электрон)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
