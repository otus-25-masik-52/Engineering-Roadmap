      "locked": false
    },
    {
      "id": "BRKGUaHmMf4CIGMJx9LOo",
      "type": "text",
      "x": 520,
      "y": -500,
      "width": 940,
      "height": 80,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "2mPc-oKLLNovfxC_lx4nw"
      ],
      "frameId": "abfpzohTRiR-xsawwguyo",
      "index": "aA",
      "roundness": null,
      "seed": 252208933,
      "version": 177,
      "versionNonce": 164069439,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1782160585804,
      "link": null,
      "locked": false,
      "text": "Легирование – это процесс введения в состав металлов и сплавов дополнительных элементов (легирующих элементов)\nс целью улучшения их физических, химических, механических или технологических свойств. Такие материалы\nназываются легированными. То есть, простыми словами, путём добавления примесей можно измененить физическую\nхарактеристику кремния, в данном случае электропроводимость.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Легирование – это процесс введения в состав металлов и сплавов дополнительных элементов (легирующих элементов) с целью улучшения их физических, химических, механических или технологических свойств. Такие материалы называются легированными. То есть, простыми словами, путём добавления примесей можно измененить физическую характеристику кремния, в данном случае электропроводимость.",
      "autoResize": false,
      "lineHeight": 1.25
    },
