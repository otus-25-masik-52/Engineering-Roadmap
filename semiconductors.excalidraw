:620,"seed":621586725,"boundElements":[],"y":-380,"opacity":100,"height":360,"width":860,"frameId":"abfpzohTRiR-xsawwguyo","strokeStyle":"solid","versionNonce":1158466257},{"seed":849542757,"strokeStyle":"solid","id":"ikEQmissxiGNjfm7y4mVY","strokeWidth":2,"roughness":1,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160585804,"locked":false,"text":"Если мы добавим: бор или алюминий или галлий или индий","version":329,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"a6K","roundness":null,"containerId":null,"originalText":"Если мы добавим: бор или алюминий или галлий или индий","height":20,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":["c1muQITFfv8kHFk7uEVJi"],"versionNonce":1997981375,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"abfpzohTRiR-xsawwguyo","boundElements":[],"x":640,"angle":0,"y":-320,"width":453.58370971679688},{"seed":1826613701,"strokeStyle":"solid","id":"CGzll97I7Vo9dYc9HJ3vi","strokeWidth":1,"roughness":1,"isDeleted":true,"fontSize":16,"opacity":100,"verticalAlign":"top","updated":1782160585804,"locked":false,"text":"то на выходе получим атом-примесь с 3 валентными электронами: для 4-й связи не хватает электрона,\nпоэтому появляется дырка и электрон из соседней связи может перескочить и “закрыть” дырку, но тогда\nдырка появляется там, откуда он ушёл. Физически двигаются электроны, но описывать это удобно так,\nбудто движется положительная дырка, отсюда и название P-type (от слова positive).","version":682,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"a6Q","roundness":null,"containerId":null,"originalText":"то на выходе получим атом-примесь с 3 валентными электронами: для 4-й связи не хватает электрона, поэтому появляется дырка и электрон из соседней связи может перескочить и “закрыть” дырку, но тогда дырка появляется там, откуда он ушёл. Физически двигаются электроны, но описывать это удобно так, будто движется положительная дырка, отсюда и название P-type (от слова positive).","height":80,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":["c1muQITFfv8kHFk7uEVJi"],"versionNonce":1068320945,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":"abfpzohTRiR-xsawwguyo","boundElements":[],"x":640,"angle":0,"y":-120,"width":820},{"isDeleted":true,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":["kY_Gq_hpWbiHyV7456swk","c1muQITFfv8kHFk7uEVJi"],"index":"a6W","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":1,"version":264,"roundness":{"type":2},"type":"ellipse","updated":1782160585804,"id":"NhoELnSbjFvmZsNQPfxaM","x":700,"seed":1903954245,"boundElements":[],"y":-260,"opacity":100,"height":100,"width":100,"frameId":"abfpzohTRiR-xsawwguyo","strokeStyle":"solid","versionNonce":1395496671},{"isDeleted":true,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":["kY_Gq_hpWbiHyV7456swk","c1muQITFfv8kHFk7uEVJi"],"index":"a6c","backgroundColor":"#ffec99","angle":0,"fillStyle":"solid","strokeWidth":1,"version":261,"roundness":{"type":2},"type":"ellipse","updated":1782160585804,"id":"U9w8Iaetd4zawGoE2qVWu","x":720,"seed":1175754917,"boundElements":[],"y":-240,"opacity":100,"height":20,"width":20,"frameId":"abfpzohTRiR-xsawwguyo","strokeStyle":"solid","versionNonce":1900219025},{"isDeleted":true,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":["kY_Gq_hpWbiHyV7456swk","c1muQITFfv8kHFk7uEVJi"],"index":"a6f","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":1,"version":258,"roundness":{"type":2},"type":"ellipse","updated":1782160585804,"id":"hY-Xan8tr2s6d7bicus8i","x":740,"seed":1269054469,"boundElements":[],"y":-240,"opacity":100,"height":20,"width":20,"frameId":"abfpzohTRiR-xsawwguyo","strokeStyle":"solid","versionNonce":3498751},{"isDeleted":true,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":["kY_Gq_hpWbiHyV7456swk","c1muQI