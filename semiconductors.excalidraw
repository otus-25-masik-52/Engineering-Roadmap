    },
    {
      "id": "buwVwtTBKQcCTUNGDwDKd",
      "type": "text",
      "x": 5605,
      "y": -2230,
      "width": 777.6314086914062,
      "height": 220,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0Zzzzzzzzzzzzzzzzzzzzzzzzzzzzzy",
      "roundness": null,
      "seed": 95010353,
      "version": 280,
      "versionNonce": 1646940735,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1782160485834,
      "link": null,
      "locked": false,
      "text": "Часть предсказателя переходов, которая отвечает на вопрос: “Переход сработает или нет?”\nНапример для инструкции:\n\n0x1004: jle 0x1010\n\nварианты такие:\ntaken -> перейти на 0x1010\nnot taken -> идти дальше на 0x1008\n\nСостоит из таблицы маленьких счётчиков; индексации по адресу инструкции; индексации по истории\nпереходов; логики выбора ответа taken/not taken.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "yhCA9kpazp8FC-ezU6801",
      "originalText": "Часть предсказателя переходов, которая отвечает на вопрос: “Переход сработает или нет?”\nНапример для инструкции:\n\n0x1004: jle 0x1010\n\nварианты такие:\ntaken -> перейти на 0x1010\nnot taken -> идти дальше на 0x1008\n\nСостоит из таблицы маленьких счётчиков; индексации по адресу инструкции; индексации по истории переходов; логики выбора ответа taken/not taken.",
      "autoResize": true,
      "lineHeight": 1.25
    },
