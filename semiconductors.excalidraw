    {
      "id": "Y3XBM70pkj-M_ouuMYatN",
      "type": "text",
      "x": 2545,
      "y": 5000,
      "width": 423.3756103515625,
      "height": 60,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
