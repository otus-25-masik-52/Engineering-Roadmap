      "link": null,
      "locked": false
    },
    {
      "id": "QpEc63Ymo6oKCbSgu_Xnc",
      "type": "text",
      "x": 6905,
      "y": -2130,
      "width": 772.0953369140625,
      "height": 160,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0Zzzzzzzzzzzzzzzzzzzzzzzzzzzzzd",
      "roundness": null,
      "seed": 1711742559,
      "version": 340,
      "versionNonce": 936385905,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1782160485834,
      "link": null,
      "locked": false,
      "text": "Таблица, которая хранит адреса, куда обычно прыгают переходы. Проще: Direction Predictor\nговорит: “прыгать”, а BTB говорит: “прыгать вот сюда: 0x1010”, например:\n\n0x1004: jle 0x1010\n\nBTB может хранить: адрес перехода: 0x1004; цель перехода: 0x1010\n\nBTB похож на маленький кэш: теги; адреса целей; valid bits; логика сравнения; логика замещения.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "hXnqz4I-ngtWlfzkM17Ie",
      "originalText": "Таблица, которая хранит адреса, куда обычно прыгают переходы. Проще: Direction Predictor говорит: “прыгать”, а BTB говорит: “прыгать вот сюда: 0x1010”, например:\n\n0x1004: jle 0x1010\n\nBTB может хранить: адрес перехода: 0x1004; цель перехода: 0x1010\n\nBTB похож на маленький кэш: теги; адреса целей; valid bits; логика сравнения; логика замещения.",
      "autoResize": true,
      "lineHeight": 1.25
    },
