    {
      "id": "26HpRV67CPUbf2HykjnsX",
      "type": "text",
      "x": 3140,
      "y": 5860,
      "width": 1059.9999999999995,
      "height": 120,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "62bq_tkki6jhixpW-9Skc"
      ],
      "frameId": "zwHZW-FslHRFxSNZRdbqr",
      "index": "b96zzzC",
      "roundness": null,
      "seed": 453217504,
      "version": 321,
      "versionNonce": 165862897,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1782160491313,
      "link": null,
      "locked": false,
      "text": "Эмиттер – это область транзистора, которая вводит (инжектирует) носители заряда (электроны или дырки) в область базы. Он\nобеспечивает ввод носителей заряда в транзистор.\n\nОсобенности:\n- обычно сильно легируется (имеет высокую концентрацию примесей), чтобы обеспечить высокую концентрацию носителей заряда;\n- обеспечивает ввод или вывод носителей заряда в транзистор.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Эмиттер – это область транзистора, которая вводит (инжектирует) носители заряда (электроны или дырки) в область базы. Он обеспечивает ввод носителей заряда в транзистор.\n\nОсобенности:\n- обычно сильно легируется (имеет высокую концентрацию примесей), чтобы обеспечить высокую концентрацию носителей заряда;\n- обеспечивает ввод или вывод носителей заряда в транзистор.",
      "autoResize": false,
      "lineHeight": 1.25
    },
