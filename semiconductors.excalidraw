    {
      "id": "lyCQDO7s_DLSoMNc4CY6d",
      "type": "text",
      "x": 5605,
      "y": -1330,
      "width": 773.0713500976562,
      "height": 240,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
